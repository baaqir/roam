# Both keys are OPTIONAL. Without them, the app uses static fallback estimates.
# With them, flights and lodging are priced via live web search.

# Get a free Tavily API key at https://tavily.com (designed for LLM agents)
TAVILY_API_KEY=

# Get an Anthropic API key at https://console.anthropic.com
# Used to extract structured prices from search snippets via Claude Haiku.
ANTHROPIC_API_KEY=
